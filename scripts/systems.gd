	{ "id": ALIEN, "name": "Alien Zone", "ly": 666.0, "ra": 0.0, "dec": 0.0, "spectral": "—", "color": Color(0.95, 0.15, 0.12), "hostile": true, "map": Vector2(-30.0, -26.0) },
]

static var _by_id := {}   # id -> row (lazy union of AUTHORED + STARS, authored first)

# --- catalogue lookup -------------------------------------------------------
static func _rows() -> Dictionary:
	if _by_id.is_empty():
		for r in AUTHORED:
			_by_id[r.id] = r
		for r in STARS:
			_by_id[r.id] = r
	return _by_id

static func _row(id: String) -> Dictionary:
	return _rows().get(id, {})

# Every travel destination (authored + real stars). The Interstellar hub is NOT a
# catalogue destination — it's the deep-space junction you pass through.
static func all() -> Array:
	return _rows().keys()

static func display_name(id: String) -> String:
	if id == INTERSTELLAR:
		return "Interstellar"
	var r := _row(id)
	return str(r.get("name", id)) if not r.is_empty() else id

static func light_years(id: String) -> float:
	return float(_row(id).get("ly", 0.0))

static func spectral(id: String) -> String:
	return str(_row(id).get("spectral", ""))

static func star_color(id: String) -> Color:
	return _row(id).get("color", Color(1, 1, 1))

# Hostile systems spawn the always-on alien swarm + Vortex boss. (Per-star GUARDIANS that
# gate discovery are separate — see main._is_guarded.)
static func is_hostile(id: String) -> bool:
	return bool(_row(id).get("hostile", false))


# Real 3D position from Sol in light-years (RA/Dec/distance → cartesian). Used for the
# star-map layout and for distance-scaled transit between any two systems.
static func coord(id: String) -> Vector3:
	var r := _row(id)
	var ra := deg_to_rad(float(r.get("ra", 0.0)))
	var dec := deg_to_rad(float(r.get("dec", 0.0)))
	var d := float(r.get("ly", 0.0))
	return Vector3(d * cos(dec) * cos(ra), d * sin(dec), d * cos(dec) * sin(ra))

# 2D chart position for the star map (equatorial-plane projection of coord). The Alien
# zone uses a hand-set `map` override since it isn't a real sky position.
static func galaxy_pos(id: String) -> Vector2:
	var r := _row(id)
	if r.has("map"):
		return r.map
	var c := coord(id)
	return Vector2(c.x, c.z)


# --- Interstellar hub (unchanged): a fixed, flyable layout of the original gate-suns,
# the navigable IMAGINARY-WORMHOLE field. Real light-years are too far to fly, so the hub
# holds one imaginary wormhole per star, laid out in the star's REAL sky direction at a
# flyable (sqrt-compressed, capped) distance. You navigate to a wormhole and fly through it
# to reach its star. main shows only the wormholes the player KNOWS (visited / unlocked /
# radar-found). ---
const WH_MIN_R := 600.0       # nearest wormhole ring distance in the hub
const WH_MAX_R := 3000.0      # farthest (kept float-safe + flyable)
const WH_PER_SQRTLY := 230.0  # ring distance ≈ this × sqrt(light-years)

# Hub position of a star's imaginary wormhole: its real 3D sky direction × a compressed,
# capped distance (near stars' gates sit closer; far ones further, but all reachable).
static func wormhole_pos(star: String) -> Vector3:
	var dir := coord(star)
	dir = dir.normalized() if dir.length() > 0.001 else Vector3(0, 0, -1)
	var r: float = clampf(sqrt(light_years(star)) * WH_PER_SQRTLY, WH_MIN_R, WH_MAX_R)
	return dir * r

# Every imaginary wormhole (one per star, home excluded — Sol is reached by emergency-home).
# Each: { pos, dest, dest_ly, station }. main filters this to the KNOWN set for
# visibility/navigation. `station` = this wormhole carries a dockable space platform.
static func all_wormholes() -> Array:
	var out := []
	for id in all():
		if id == SOL:
			continue
		out.append({
			"pos": wormhole_pos(id), "dest": id, "dest_ly": light_years(id),
			"station": has_station(id),
		})
	return out

# --- Space-platform network --------------------------------------------------
# ~half the wormholes carry a dockable space platform, picked so they're spread evenly
# across the field — so from any wormhole the nearest platform is close (you teleport
# platform→platform, then fly the short rest). Selection is FIXED catalogue geometry:
# deterministic, no persistence. Algorithm = farthest-point sampling (greedy max-min):
# seed at the platform nearest the hub entry, then repeatedly add the wormhole farthest
# from every platform already chosen — which directly minimises the worst-case "how far
# to the nearest platform" over all wormholes.
const STATION_FRAC := 0.5

static var _station_set := {}   # star id -> true (lazy, see has_station)

static func has_station(star: String) -> bool:
	if star == SOL:
		return false
	if _station_set.is_empty():
		_station_set = _compute_stations()
	return _station_set.has(star)

static func _compute_stations() -> Dictionary:
	var ids := []
	var pos := {}
	for id in all():
		if id == SOL:
			continue
		ids.append(id)
		pos[id] = wormhole_pos(id)
	var chosen := {}
	if ids.is_empty():
		return chosen
	var target: int = int(round(ids.size() * STATION_FRAC))
	# Seed: the wormhole nearest the hub entry point (home-adjacent coverage first).
	var entry := arrival_pos(INTERSTELLAR)
	var seed_id: String = ids[0]
	var best := INF
	for id in ids:
		var d: float = (pos[id] - entry).length()
		if d < best:
			best = d
			seed_id = id
	chosen[seed_id] = true
	# Greedily add the wormhole farthest from the nearest already-chosen platform.
	while chosen.size() < target:
		var far_id := ""
		var far_d := -1.0
		for id in ids:
			if chosen.has(id):
				continue
			var nd := INF
			for c in chosen:
				nd = minf(nd, (pos[id] - pos[c]).length())
			if nd > far_d:
				far_d = nd
				far_id = id
		if far_id == "":
			break
		chosen[far_id] = true
	return chosen

# --- Wormhole NETWORK: a connected graph of point-to-point links --------------
# Wormholes are rewards, not a single field — each system hosts only its few graph
# NEIGHBOURS, and you hop system→system, routing multi-hop over the links you know
# ("go to Proxima first, then Alpha"). Built from the real 3D coords: a minimum spanning
# tree backbone (guarantees EVERY star is reachable from Sol — the whole point of the game)
# plus a few extra short edges for alternate routes. Links are bidirectional.
const WH_EXTRA_EDGES := 9     # short non-tree links added on top of the MST (alternate routes)
const WH_MAX_DEGREE := 4      # cap links per system for the EXTRA edges (keeps each "limited")

static var _adj := {}          # id -> Array[ neighbour id ]  (lazy, see _ensure_graph)
static var _edges := []        # Array[ [a, b] ]  with a,b ids (each link once)

static func _ensure_graph() -> void:
	if not _adj.is_empty():
		return
	# The Interstellar hub is kept as a graph NODE you can pass through (user's call), placed
	# centrally just "above" Sol so the MST links it in as a low-degree junction near home.
	var ids := all() + [INTERSTELLAR]      # 51 systems + the hub
	var pos := {}
	for id in ids:
		_adj[id] = []
		pos[id] = Vector3(0.0, 3.0, 0.0) if id == INTERSTELLAR else coord(id)
	# Prim's MST from Sol — connects every system over the shortest total link length.
	var in_tree := {}
	var start: String = SOL if ids.has(SOL) else ids[0]
	in_tree[start] = true
	while in_tree.size() < ids.size():
		var bd := INF
		var ba := ""
		var bb := ""
		for a in in_tree:
			for b in ids:
				if in_tree.has(b):
					continue
				var d: float = pos[a].distance_to(pos[b])
				if d < bd:
					bd = d; ba = a; bb = b
		if bb == "":
			break
		in_tree[bb] = true
		_link(ba, bb)
	# A few extra SHORT non-tree links (alternate routes), respecting the degree cap.
	var cand := []
	for i in ids.size():
		for j in range(i + 1, ids.size()):
			var a: String = ids[i]
			var b: String = ids[j]
			if _adj[a].has(b):
				continue
			cand.append({ "a": a, "b": b, "d": pos[a].distance_to(pos[b]) })
	cand.sort_custom(func(x, y): return x.d < y.d)
	var added := 0
	for c in cand:
		if added >= WH_EXTRA_EDGES:
			break
		if _adj[c.a].size() >= WH_MAX_DEGREE or _adj[c.b].size() >= WH_MAX_DEGREE:
			continue
		_link(c.a, c.b)
		added += 1

static func _link(a: String, b: String) -> void:
	if not _adj[a].has(b):
		_adj[a].append(b)
	if not _adj[b].has(a):
		_adj[b].append(a)
	_edges.append([a, b])

# The systems this one links to directly (its hosted wormholes).
static func neighbors(id: String) -> Array:
	_ensure_graph()
	return _adj.get(id, [])

# Every link in the network, as [a, b] id pairs (each once) — for the map's lane lines.
static func wh_edges() -> Array:
	_ensure_graph()
	return _edges

# Shortest-path NEXT HOP from `from` toward `to` over links the player KNOWS. `known` is an
# optional Callable(a, b) -> bool gating each edge (omit = full graph). "" if no known route.
static func next_hop(from: String, to: String, known := Callable()) -> String:
	if from == to or from == "" or to == "":
		return ""
	_ensure_graph()
	var prev := { from: "" }
	var q := [from]
	while not q.is_empty():
		var cur: String = q.pop_front()
		if cur == to:
			break
		for nb in _adj.get(cur, []):
			if prev.has(nb):
				continue
			if known.is_valid() and not known.call(cur, nb):
				continue
			prev[nb] = cur
			q.append(nb)
	if not prev.has(to):
		return ""
	var path := []
	var node := to
	while node != "":
		path.append(node)
		node = prev.get(node, "")
	path.reverse()
	return path[1] if path.size() >= 2 and path[0] == from else ""


# The hub has NO sun-bodies — it IS the wormhole field; the portals (Wormhole node) are the
# only objects out here, plus the fixed starfield backdrop.
static func _interstellar() -> Array:
	return []


# Short arrival lore (shown once, the first time you reach a system). Empty = no card.
static func lore(id: String) -> String:
	return {
		PROXIMA: "The nearest other sun — a dim red coal 4.24 light-years out, and the\nfirst light most pilots ever claim that isn't our own. Proxima b huddles\nclose to its fire, scorched on one face and frozen on the other.",
		TRAPPIST: "An ultra-cool dwarf with seven worlds packed tight around it, close\nenough that from one you'd see the others as moons. The Survey sends\nits steady hands here — a lot of beacons to plant, all within reach.",
		K2_18: "124 light-years out: a sub-Neptune in its star's temperate lane, the\nkind of world the old telescopes argued over for decades. A long haul\nfor one line in the Atlas — but it's a line few names are on.",
		ALIEN: "Past the safe lanes. The hostiles drift here, and among them Vortex —\nan alien hull grown monstrous, lit with a red menace the dark can't\nswallow. The deep catalog lies on the far side of him. Fly armed.",
		INTERSTELLAR: "The deep between the stars — every charted sun hangs here as a gate.\nPick a light and dive into it. From here the whole network is open.",
	}.get(id, "")

# Where the ship emerges (small local coord) when arriving in a system. Catalogue stars
# (not listed) get a sensible default just off the star.
static func arrival_pos(id: String) -> Vector3:
	return {
		SOL: Vector3(-8.1, -19.7, -45.3), K2_18: Vector3(30.0, 6.0, -25.0),
		PROXIMA: Vector3(25.0, 5.0, -30.0), TRAPPIST: Vector3(32.0, 6.0, -35.0),
		ALIEN: Vector3(0.0, 15.0, -70.0),
		INTERSTELLAR: Vector3(0.0, 200.0, 600.0),   # emerge just "south" of the Sol gate-sun
	}.get(id, Vector3(28.0, 6.0, -34.0))

# Wormhole portals = this system's GRAPH NEIGHBOUR links, each placed in local space in the
# real sky DIRECTION of the system it leads to (so the gate to Alpha sits where Alpha is).
# dest_ly = the real light-year HOP distance (drives transit time). main filters these to the
# links the player KNOWS before showing them (see main._known_portals).
const PORTAL_LOCAL_R := 2600.0   # how far out (local units) the gates sit from the star
static func portals(id: String) -> Array:
	_ensure_graph()
	var out := []
	var base := coord(id) if id != INTERSTELLAR else Vector3(0.0, 3.0, 0.0)
	var nbs := neighbors(id)
	var i := 0
	for nb in nbs:
		var nb_coord := coord(nb) if nb != INTERSTELLAR else Vector3(0.0, 3.0, 0.0)
		var dir := nb_coord - base
		dir = dir.normalized() if dir.length() > 0.001 else Vector3(0.0, 0.0, -1.0)
		# Spread gates in height so near-parallel directions don't overlap.
		var lift := 220.0 * (float(i) - (nbs.size() - 1) * 0.5)
		out.append({
			"pos": dir * PORTAL_LOCAL_R + Vector3(0.0, lift, 0.0),
			"dest": nb,
			"dest_ly": maxf(base.distance_to(nb_coord), 0.1),
		})
		i += 1
	return out


static func bodies(id: String) -> Array:
	match id:
		INTERSTELLAR: return _interstellar()
		SOL:      return _sol()
		K2_18:    return _k2_18()
		PROXIMA:  return _proxima()
		TRAPPIST: return _trappist()
		ALIEN:    return _alien()
		_:        return [_single_star(_row(id))]


# A real catalogue star: a single tinted sol.obj sun at the arena origin. mass gives it a
# slow-zone so you can settle in to fight/discover it.
static func _single_star(r: Dictionary) -> Dictionary:
	return {
		"name": str(r.get("name", "Star")), "radius": 5.0, "mass": 40000.0,
		"color": r.get("color", Color(1, 1, 1)), "glow": 2.0,
		"star": true, "live": false, "pos": Vector3.ZERO, "model": STAR_MODEL,
		"spectral": str(r.get("spectral", "")),
	}


# Sol: the live bodies from Ephemeris (Sun + planets), tagged live so
# PlanetSystem reads their real Horizons positions each frame.
static func _sol() -> Array:
	var out := []
	for p in Ephemeris.PLANETS:
		var b := {
			"name": p.name, "radius": p.radius, "color": p.color,
			"glow": p.get("glow", 1.0), "star": p.get("star", false),
			"mass": p.get("mass", 1.0),    # real mass (Earth=1) drives the force-slow zone
			"ring": p.get("ring", false),  # Saturn's ring
			"craft": p.get("craft", false),   # Voyagers drift outward forever
			"drift": p.get("drift", 0.0),
			"live": true, "pos": Vector3.ZERO,
		}
		if p.has("model"):
			b["model"] = p.model
		out.append(b)
	# Major moons orbit their live parent planet each frame (see PlanetSystem.refresh).
	for m in Ephemeris.MOONS:
		out.append({
			"name": m.name, "radius": m.radius, "color": m.color, "glow": m.get("glow", 0.25),
			"mass": m.get("mass", 0.01), "star": false, "live": false, "pos": Vector3.ZERO,
			"parent": m.parent, "orbit_r": m.orbit_r, "orbit_speed": m.orbit_speed,
		})
	return out


# K2-18: a real M-dwarf (~124 ly) with its real planets. K2-18b is the famous
# sub-Neptune "hycean" candidate at 0.143 AU; K2-18c orbits inside it at 0.067 AU.
static func _k2_18() -> Array:
	return [
		{ "name": "K2-18",  "radius": 6.0, "mass": 120000.0, "color": Color(1.0, 0.45, 0.28), "glow": 2.0,
			"star": true, "live": false, "pos": Vector3(0, 0, 0), "model": STAR_MODEL },
		{ "name": "K2-18b", "radius": 3.8,  "color": Color(0.32, 0.62, 0.78), "glow": 0.5,
			"star": false, "live": false, "pos": Vector3(12.0, 1.0, 8.0) },   # 0.143 AU
		{ "name": "K2-18c", "radius": 2.0,  "color": Color(0.75, 0.6, 0.5),   "glow": 0.35,
			"star": false, "live": false, "pos": Vector3(-5.5, 0.5, 4.0) },   # 0.067 AU
	]


