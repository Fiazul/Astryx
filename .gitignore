# Godot 4+ — generated import cache (regenerated on open; never commit)
.godot/

# Secrets — the real NASA key lives only in your local .env, never in git.
# (Astryx doesn't actually need it: positions come from the keyless JPL
# Horizons API. See .env.example.)
.env

# Editor / OS cruft
.DS_Store
Thumbs.db
*~
*.tmp
*.bak

# Build artifacts — exported binaries are published as GitHub Release assets,
# not committed to source history (they'd bloat the repo / hit the 100MB limit).
builds/

CLAUDE.FILE/

# Claude Code / local agent config (machine-local, not project source)
.claude/
.agents/
skills-lock.json

# Python bytecode cache
__pycache__/

# Raw star catalogues — huge (~340MB); regenerated by tools/parse_tycho.py and
# already excluded from game exports via tools/data/.gdignore.
tools/data/

# Local audio preview artifacts
tools/booster_preview.wav
tools/booster_preview.wav.import
